# Fundamental Agent — Environment Configuration
# Copy this file to .env and fill in your API key

# ─── Required ───────────────────────────────────────────
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# ─── OpenRouter Fallback (activates automatically when Anthropic credits run out) ───
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here
# Analysis model (reasoning) — used when Anthropic is down for the main 4-gate analysis
OPENROUTER_MODEL=google/gemma-4-31b-it
# Search model — MUST have live web search; Perplexity Sonar fetches real-time prices & data
# Do NOT change this to a model without web search or stock prices will be stale/wrong
OPENROUTER_SEARCH_MODEL=perplexity/sonar

# ─── Optional ───────────────────────────────────────────
PORT=3001
NODE_ENV=development
