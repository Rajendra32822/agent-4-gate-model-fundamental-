# Fundamental Agent — Environment Configuration
# Copy this file to .env and fill in your API key

# ─── Required ───────────────────────────────────────────
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# ─── OpenRouter Fallback (activates automatically when Anthropic credits run out) ───
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here
# Model to use on OpenRouter — default is google/gemma-3-27b-it
# Find model IDs at: https://openrouter.ai/models
OPENROUTER_MODEL=google/gemma-3-27b-it

# ─── Optional ───────────────────────────────────────────
PORT=3001
NODE_ENV=development
