# Fundamental Agent — Environment Configuration
# Copy this file to .env and fill in your API key

# ─── Required ───────────────────────────────────────────
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# ─── OpenRouter Fallback (activates automatically when Anthropic credits run out) ───
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here
# Analysis model — free, no credits needed, good for reasoning
OPENROUTER_MODEL=google/gemma-4-31b-it:free
# Search model — free, no credits needed (WARNING: no live web access, prices will be from training data)
# Upgrade to perplexity/sonar ($1/M tokens) for real-time prices when Anthropic is down
OPENROUTER_SEARCH_MODEL=google/gemma-4-26b-a4b-it:free

# ─── Optional ───────────────────────────────────────────
PORT=3001
NODE_ENV=development
